# Copy this file to .env and adjust values.
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Database. Leave DATABASE_URL empty to use SQLite (MVP default).
# For PostgreSQL set e.g.:
# DATABASE_URL=postgres://user:password@localhost:5432/tender_portal
DATABASE_URL=

# Fetch / scraping controls
FETCH_REQUEST_DELAY=1.5
FETCH_MAX_RETRIES=3
FETCH_TIMEOUT=30
FETCH_MANUAL_COOLDOWN=60
# Use mock adapter for tenders (True for MVP, False to attempt live EKAP)
EKAP_DATA_MODE=live

# Trial length (days) for newly created profiles
DEFAULT_TRIAL_DAYS=14
